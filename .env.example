# Firebase — copie este arquivo para .env e preencha com suas chaves
VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Cloudflare Stream (usado pelo player HLS atual — será descontinuado na Fase 2 do roadmap)
VITE_CLOUDFLARE_ACCOUNT_ID=your_account_id
VITE_CLOUDFLARE_STREAM_TOKEN=your_stream_token

# Cloudflare R2 — armazenamento de vídeo bruto + panoramas gerados pelo pipeline SLAM
# Usado por gerar_quadros.py (worker) e pelas futuras URLs assinadas de upload direto do navegador.
# NÃO prefixar com VITE_ (essas chaves só devem ser usadas no worker/servidor, nunca expostas no client).
R2_ACCOUNT_ID=your_r2_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=your_r2_bucket_name
R2_PUBLIC_URL=https://pub-xxx.r2.dev
